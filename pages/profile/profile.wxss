page {
  background-color: #f5f7fa;
}

.container {
  padding: 0;
}

/* 用户信息区域 */
.profile-header {
  background: linear-gradient(180deg, #1989fa 0%, #1067c7 100%);
  padding: 60rpx 30rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.profile-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background-color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.avatar-img {
  width: 140rpx;
  height: 140rpx;
}

.avatar-placeholder {
  width: 140rpx;
  height: 140rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-placeholder text {
  font-size: 48rpx;
  font-weight: 600;
  color: #1989fa;
}

.profile-info {
  margin-top: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.profile-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
}

.profile-role {
  margin-top: 12rpx;
  padding: 8rpx 24rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  color: #fff;
  background-color: rgba(255, 255, 255, 0.2);
}

.profile-role.admin {
  background-color: rgba(255, 255, 255, 0.25);
}

/* 登录卡片 */
.login-card {
  background: linear-gradient(180deg, #1989fa 0%, #1067c7 100%);
  padding: 80rpx 40rpx;
}

.login-content {
  background-color: #fff;
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.login-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.login-desc {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 40rpx;
  text-align: center;
}

.login-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
}

/* 菜单卡片 */
.menu-card {
  background-color: #fff;
  border-radius: 24rpx;
  margin: -20rpx 20rpx 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-left {
  display: flex;
  align-items: center;
}

.menu-icon {
  font-size: 40rpx;
  margin-right: 24rpx;
}

.menu-text {
  font-size: 30rpx;
  color: #333;
}

.menu-arrow {
  font-size: 28rpx;
  color: #ccc;
}

/* 按钮容器 */
.btn-container {
  padding: 0 30rpx;
  margin-top: 20rpx;
  box-sizing: border-box;
  width: 100%;
  text-align: center;
}

.btn-block {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  border-radius: 44rpx;
  margin: 0;
}

.btn-danger {
  background-color: #fff;
  color: #fa5151;
  border: 1rpx solid #fa5151;
}

/* 关于信息 */
.about-info {
  text-align: center;
  padding: 60rpx 40rpx;
}

.version {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 10rpx;
}

.copyright {
  font-size: 22rpx;
  color: #ccc;
}
